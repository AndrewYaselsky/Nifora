        "ggj-_y-Y_PO_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0829/5330/6368/files/5_10_eb161fea-ca4e-4f2c-8724-8fb42aa0f86a.png",
        "ggj-_y-Y_PO_srcSet_mobile_src": "https://cdn.shopify.com/s/files/1/0798/4028/0923/files/5_10.png",
        "ggj-_y-Y_PO_srcSet_tablet_src": "https://cdn.shopify.com/s/files/1/0798/4028/0923/files/5_10.png",
        "ggj-b7-Ufnz_text": "Here are the 7 reasons why I’ve actually stuck with it:",
        "ggjPk9bJpvM_text": "3. It’s The Ultimate 3-in-1 Multitasker",
        "ggjpl9EZF7-_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0798/4028/0923/files/d0af24a7-5b52-4e74-b870-e93a5ce17581.jpg",
        "ggjpl9EZF7-_srcSet_mobile_src": "https://cdn.shopify.com/s/files/1/0798/4028/0923/files/d0af24a7-5b52-4e74-b870-e93a5ce17581.jpg",
        "ggjpl9EZF7-_srcSet_tablet_src": "https://cdn.shopify.com/s/files/1/0798/4028/0923/files/d0af24a7-5b52-4e74-b870-e93a5ce17581.jpg",
        "ggl71u75c7R_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0829/5330/6368/files/15_c939a447-d4d1-46c0-af32-d4f1d4cd04d1.png",
        "ggl71u75c7R_srcSet_mobile_src": "https://cdn.shopify.com/s/files/1/0829/5330/6368/files/15_c939a447-d4d1-46c0-af32-d4f1d4cd04d1.png",
        "ggl71u75c7R_srcSet_tablet_src": "https://cdn.shopify.com/s/files/1/0798/4028/0923/files/15_010c2149-8447-41b5-ae4e-398283c40a19.png",
