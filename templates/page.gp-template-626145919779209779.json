        "gggTy2IY0Ux_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0829/5330/6368/files/Group_37930_2_1_70c03fae-b732-46aa-bb33-b11ee550a6b8.png",
        "gglV0yKrbqN_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0829/5330/6368/files/A_glow_getter_skincare_routine_focuses_on.jpg",
