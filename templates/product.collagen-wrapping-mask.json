    "ss_testimonial_10_MJHF8K": {
      "type": "ss-testimonial-10",
      "blocks": {
        "testimonial_78YWhM": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/716BoeuJU3L.jpg",
            "stars_count": 5,
            "text": "<p>“I’ve tried so many overnight masks, but this one really impressed me. My skin felt noticeably firmer and smoother after just two uses. At 42, hydration is everything—and this mask locks it in beautifully without feeling greasy.”</p>",
            "author": "- Linda"
          }
        },
        "testimonial_HMtQi7": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/711NBlM4WeL.jpg",
            "stars_count": 5,
            "text": "<p>\"The fine lines around my eyes are less noticeable in the morning when I use this. It peels off easily, and my skin looks fresh and dewy. I just wish the jar was a little bigger—but I’m definitely repurchasing!\"</p>",
            "author": "- Monica"
          }
        },
        "testimonial_xpigwP": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/71JJaV7_vJL.jpg",
            "stars_count": 5,
            "text": "<p>\"“Love this mask! My skin used to feel dry and tight by morning, but not anymore. It gives me that 'plump and rested' look. I'm always up early for work, and this helps me look like I got a full 8 hours of sleep!”\"</p>",
            "author": "- Rachel"
          }
        },
        "testimonial_yyRRp8": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/71pOCoWDNiL.jpg",
            "stars_count": 5,
            "text": "<p>\"As someone with sensitive, mature skin, I’m always cautious. But this mask worked wonders! No irritation, no breakouts—just soft, hydrated skin. My makeup goes on much smoother after using it overnight.\"</p>",
            "author": "- Tina"
          }
        },
        "testimonial_K9emEj": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/6c6a8c28d9271968252f2b9d8f0d1ed3.jpg",
            "stars_count": 5,
            "text": "<p>“This product gave me real results. I use it twice a week and have noticed my skin looks brighter, less dull, and more even. It’s like a mini facial while I sleep. Highly recommend for women in their late 30s and up!”</p>",
            "author": "- Jessie"
          }
        }
      },
