        "ggvDN5djePx_text": "<p>Who says glowing skin has to be expensive? The right products can transform your skin without breaking the bank! Healthy, radiant skin doesn't have to cost a fortune!</p>",
        "ggw6GWQLv30_text": "<p>Instant Glow in 1-2 Uses</p>",
        "ggxK_8Xcm8n_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0798/4028/0923/files/Bonnie1_3.png",
        "ggxK_8Xcm8n_srcSet_mobile_src": "https://cdn.shopify.com/s/files/1/0798/4028/0923/files/Bonnie1_3.png",
