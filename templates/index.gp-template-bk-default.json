    "ss_product_ingredients_6_ypJenR": {
      "type": "ss-product-ingredients-6",
      "blocks": {
        "heading_NnT3j4": {
          "type": "heading",
          "settings": {
            "heading": "<p><strong>Every Ingredient Carefully Chosen</strong></p>",
            "heading_custom": false,
            "heading_font": "poppins_n7",
            "heading_size": 36,
            "heading_size_mobile": 24,
            "heading_height": 130,
            "heading_mt": 0,
            "heading_mt_mobile": 0,
            "heading_color": "#8b1638"
          }
        },
        "text_WmV6A7": {
          "type": "text",
          "settings": {
            "text": "<p>Each ingredient in our Bio-Collagen Mask is <strong>thoughtfully selected and supported by science</strong>—not hype. We use no harsh fillers or hidden additives—just a clean, transparent formula formulated with well-researched ingredients like low-molecular collagen, hyaluronic acid, niacinamide, and more for visible, skin-loving results.</p>",
            "text_custom": false,
            "text_font": "josefin_sans_n4",
            "text_size": 13,
            "text_size_mobile": 13,
            "text_height": 130,
            "text_mt": 4,
            "text_mt_mobile": 12,
            "text_color": "#121212"
          }
        },
        "card_NTWq3A": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Collagen-ing.png",
            "title": "Hydrolyzed Collagen",
            "text": "<p>Deep Absorption</p>",
            "source": "",
            "modal_text": "<p><strong>Our Bio-Collagen Mask uses fish collagen</strong> — a type of animal collagen extracted from the skin, scales, and gills of fish. It is widely used in food, health care products, and cosmetics due to its excellent absorption and skin-rejuvenating properties. <strong>It helps boost firmness and elasticity</strong>, enhances hydration by locking in moisture, and <strong>supports skin repair</strong>—visibly reducing the appearance of fine lines and <strong>promoting a smoother, plumper complexion</strong>.<br/></p>",
            "modal_subtitle": "",
            "modal_sub_text": "",
            "url": ""
          }
        },
        "card_UPJaTJ": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Hyaluronix.png",
            "title": "Hyaluronic Acid",
            "text": "<p>Boosts Skin Hydration</p>",
            "source": "",
            "modal_text": "<p><strong>Hyaluronic acid </strong>is a moisture-binding ingredient that <strong>deeply hydrates the skin</strong>, helping it appear plump, smooth, and supple. It holds up to 1,000 times its weight in water,<strong> supporting skin elasticity</strong> and <strong>reducing the look of fine lines</strong>. In the Bio-Collagen Mask, it enhances absorption and boosts the mask’s firming and rejuvenating effects.</p>",
            "modal_subtitle": "",
            "modal_sub_text": "",
            "url": ""
          }
        },
        "card_hpjA6m": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Vitamin_E.png",
            "title": "Vitamin E",
            "text": "<p>Skin Repair</p>",
            "source": "",
            "modal_text": "<p><strong>Vitamin E </strong>is a powerful <strong>antioxidant</strong> that helps protect the skin from free radical damage and environmental stressors. It <strong>supports skin repair</strong>, <strong>soothes irritation</strong>, and <strong>strengthens the skin barrier</strong>. It works to nourish and protect the skin while enhancing moisture retention and promoting a smoother, healthier complexion.</p>",
            "modal_subtitle": "",
            "modal_sub_text": "",
            "url": ""
          }
        },
        "card_gbywcR": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Niacinamide.png",
            "title": "Niacinamide",
            "text": "<p>Brightening Agent</p>",
            "source": "",
            "modal_text": "<p><strong>Niacinamide </strong>is an ingredient that helps <strong>brighten skin tone</strong>, <strong>reduce the appearance of pores</strong>, and <strong>improve skin texture</strong>. It also strengthens the skin barrier, regulates oil production, and soothes inflammation—making it ideal for sensitive or aging skin. In the Bio-Collagen Mask, it enhances the overall <strong>clarity, smoothness, and resilience</strong> of the skin.</p>",
            "modal_subtitle": "",
            "modal_sub_text": "",
            "url": ""
          }
        },
        "card_J4YxU4": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Glycerin.png",
            "title": "Glycerin",
            "text": "<p>Moisture Lock</p>",
            "source": "",
            "modal_text": "<p><strong>Glycerin </strong>is a powerful humectant that draws moisture into the skin and <strong>helps maintain hydration levels</strong>. It works to soften rough patches, improve skin elasticity, and support the skin’s natural barrier. In the Bio-Collagen Mask, it helps lock in moisture,<strong> keeping the skin plump</strong>, smooth, and comfortable during and after use.</p>",
            "modal_subtitle": "",
            "modal_sub_text": "",
            "url": ""
          }
        },
        "card_Gqgzwt": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Galactomyces.png",
            "title": "Galactomyces",
            "text": "<p>Radiance Booster</p>",
            "source": "",
            "modal_text": "<p><strong>Galactomyces</strong> is a fermented yeast extract rich in vitamins, amino acids, and antioxidants that <strong>help nourish and revitalize the skin</strong>. It works to improve skin clarity, <strong>refine pores</strong>, and balance sebum production. It <strong>enhances radiance</strong>, <strong>smooths texture</strong>, and supports a brighter, more even complexion.<br/></p>",
            "modal_subtitle": "",
            "modal_sub_text": "",
            "url": ""
          }
        },
