          "settings": {
            "image": "shopify://shop_images/4.jpg",
            "stars_count": 5,
            "text": "<p>\"I barely have time for skincare, but this collagen mask is my go-to before bed. It gives me that refreshed glow even after sleepless nights.\"</p>",
            "author": "- VANESSA JOHNSON"
          }
        },
        "testimonial_K9emEj": {
