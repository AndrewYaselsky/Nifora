{% comment %}
  Save this as a new Section (e.g., sections/review-popup.liquid)
  or as a Custom Liquid block.
{% endcomment %}

{% style %}
  .review-popup-container {
    position: relative;
    margin: 5px 0;
    width: 100%;
    display: none;
  }

  .review-trigger-btn {
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .review-trigger-btn .label {
    font-size: 15px;
    color: #0B0B0B;
        margin-top: 4px;
  }

  .stars-parent {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .stars-icon {
    display: flex;
    width: 16px;
    height: 16px;
  }

  /* The Modal Card */
  .review-card-popup {
    width: 307px;
    border: 1px solid #E4E4E7;
    padding: 16px;
    color: #222222;
    position: absolute;
    z-index: 1;
    background: white;
    margin-top: 10px;
    top: 25px;
    font-family: Futura;
    box-shadow: 0px 0px 25px rgba(0, 0, 0, 0.12);
    border-radius: 6px;
    display: none;
  }

  .review-card-popup.is-visible { display: block; }

  .card-header-info {
    margin-bottom: 10px;
    display: flex;
    align-items: center;
  }

  .card-header-info .rating {
    margin-right: 5px;
  }

  .popup-close-button {
    margin-left: auto;
    width: 20px;
    height: 20px;
  }

  .based-on-text {
        font-size: 9px;
    margin-left: 6px;
    font-weight: 600;
  }

  /* Progress Bars */
  .bars-section { margin-bottom: 20px; }
  .bar-line {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
    font-size: 12px;
  }
  .bar-track {
    flex: 1;
    height: 8px;
    background: #f1f1f1;
    border-radius: 10px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    background: #ffbc0b;
    display:block !important;
  }
  .bar-count { color: #888; width: 30px; text-align: right; }

  /* Slider Styling */
  .review-slider-wrapper {
    border-top: 1px solid #eee;
    padding-top: 15px;
    min-height: 150px;
  }

  .single-slide { display: none; }
  .single-slide.active { display: block; animation: fadeIn 0.3s; }

  .user-box { display: flex; gap: 12px; align-items: center; margin-bottom: 12px; }
  .user-box img { width: 50px; height: 50px; border-radius: 6px; object-fit: cover; background: #eee; }
  .user-name-tag { font-weight: 700; font-size: 15px; color: #333; }

  .verified-badge {
    color: #27ae60;
    border: 1px solid #27ae60;
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 10px;
    text-transform: uppercase;
    font-weight: bold;
    margin-left: 5px;
  }

  .review-text-content {
    font-size: 13px;
    line-height: 1.6;
    color: #555;
    margin-bottom: 15px;
  }

  /* Slider Dots */
  .slider-nav-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 10px;
  }
  .nav-dot {
   display:block !important;
    width: 8px;
    height: 8px;
    background: #e0e0e0;
    border-radius: 50%;
    cursor: pointer;
    transition: 0.3s;
  }
  .nav-dot.active { background: #333; width: 10px; height: 10px; }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  /* reviews styling */
  .reviews-card {
        display: flex;
    gap: 10px;
    align-items: start;
    margin-bottom: 20px;
  }
  .reviews-card .reviews-image {
       width: 50px;
    height: 70px;
    min-width: 50px;
    min-height: 70px;
  }
  .reviews-card .reviews-content {
    display: flex;
    flex-direction: column;
    width: 100%;
  }
  .reviews-card .header {
    display: flex;
    align-items: center;
    padding: 0 !important;
    gap: 4px;
    width: 100%;
    font-family:inherit !important;
  }
  .reviews-card .author-name {
    font-weight: 600;
    font-size: 12px;
  }
  .reviews-card .verified-badge {
    display: flex;
    align-items: center;
    gap: 2px;
    margin: 0 !important;
    background: #ddffe6;
    padding: 3px 7px;
    border-radius: 10px;
    color: #27ae60;
    border: 1px solid #27ae60;
  }

  .reviews-card .verified-badge .icon {
        width: 7px;
    height: 8px;
    display: flex;
   }

   .reviews-card .verified-badge .text {
    font-size:10px;
    font-weight:400;
    text-transform:none;
   }

   .reviews-card .view-all-text {
    font-size: 10px;
    margin-left: auto;
   }

   .reviews-description {
    margin:0 !important;
   }

   .swiper-button-prev:after,.swiper-button-next:after {
    content:none !important;
   }

   .navigation-pagination-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
   }
   .navigation-pagination-wrapper .swiper-button-prev,
   .navigation-pagination-wrapper .swiper-button-next {
    position: relative;
    inset: 0;
    width: 36px;
    height: 36px;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    -webkit-appearance: none;
    appearance: none;
   }
   .navigation-pagination-wrapper .swiper-button-prev {
    transform: rotate(180deg);
   }
   .navigation-pagination-wrapper .swiper-button-prev svg,
   .navigation-pagination-wrapper .swiper-button-next svg {
    pointer-events: none;
    display: block;
   }
   .swiper-pagination.swiper-pagination-styling {
    position:relative;
    width:fit-content !important;
    top:0 !important;
   }

{% endstyle %}

