        "ggNArgGks0z_text": "<p>Tap below to shop the capsules everyone’s calling their “skin reset in a bottle.”</p>",
        "ggO5ZpdKbF0_label": "<p>GET YOURS NOW</p>",
        "ggPMQj66N27_label": "<p>SHOP NOW</p>",
        "ggZnRcM7c5b_text": "<p>Backed by science (not fluff)</p>",
        "ggeRmMc16gB_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0829/5330/6368/files/8_2.png",
        "ggl9_qB-jA9_text": "<p>Designed for aging, hormonal skin</p>",
