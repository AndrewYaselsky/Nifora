      "blocks": {
        "heading_DAqQJE": {
          "type": "heading",
          "settings": {
            "heading": "<p>What Sets Our Bio-Collagen Mask Apart?</p>",
            "heading_custom": false,
            "heading_font": "josefin_sans_n4",
            "heading_size": 26,
