    "ss_simple_faq_NxVU6q": {
      "type": "ss-simple-faq",
      "blocks": {
        "text_kGtL6b": {
          "type": "text",
          "settings": {
            "question": "How often should I use the mask?",
            "answer": "<p>We recommend using the mask 1–2 times per week for best results.</p>"
          }
        },
        "text_Xpzxzp": {
          "type": "text",
          "settings": {
            "question": "Can I sleep with the mask on overnight?",
            "answer": "<p>Yes! It’s designed to be worn overnight. Apply a thin layer, let it dry into a film, and peel it off in the morning.</p>"
          }
        },
        "text_BDtRac": {
          "type": "text",
          "settings": {
            "question": "Do I need to rinse my face after using it?",
            "answer": "<p>It’s not required, but you can gently rinse off any residue or follow up with your usual morning skincare routine.</p>"
          }
        },
        "text_UdqCJ3": {
          "type": "text",
          "settings": {
            "question": "Is it safe for sensitive skin?",
            "answer": "<p>Yes, the formula is fragrance-free and dermatologically tested. However, we recommend a patch test before full use.</p>"
          }
        },
        "text_3TN8mq": {
          "type": "text",
          "settings": {
            "question": "Will it help with fine lines and wrinkles?",
            "answer": "<p>Definitely. The mask contains collagen, adenosine, and hyaluronic acid to plump the skin and smooth fine lines over time.</p>"
          }
        },
        "text_Y9yyii": {
          "type": "text",
          "settings": {
            "question": "Can I use other skincare under the mask?",
            "answer": "<p>Yes! Apply your toner or serum first, then apply the mask as the final step in your nighttime routine.</p>"
          }
        },
        "text_XLQhWA": {
          "type": "text",
          "settings": {
            "question": "Does it really peel off easily in the morning?",
            "answer": "<p>Yes—as long as you apply a thin, even layer and let it dry fully, it peels off cleanly without mess.</p>"
          }
        },
        "text_TCrhAW": {
          "type": "text",
          "settings": {
            "question": "60-Day Money back-guarantee?",
            "answer": "<p>Yes! We stand behind the quality of our products. If you’re not satisfied with your purchase, you can request a return within 60 days of receiving your order. Simply contact our support team, and we’ll guide you through the process.</p>"
          }
        },
        "text_ntbDgy": {
          "type": "text",
          "settings": {
            "question": "What are the delivery times?",
            "answer": "<p><strong>Processing Time: </strong>Once your order is placed, please allow 1 business day for us to process and prepare your order for shipment.<br/><br/><strong>Shipping Time: </strong>After your order is dispatched, it will typically take 4-8 business days to reach you, depending on your location.<br/><br/><strong>Tracking Information: </strong>Once your order has been shipped, you will receive an email containing your tracking number. You can use this to track your package and stay updated on its delivery status.</p>"
          }
        }
