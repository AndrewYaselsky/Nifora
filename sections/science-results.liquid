<style>
.science-results-container {
  padding: 5px 20px;
  background: #fff;
  display: none;
}

.section-{{ section.id }} .section-title {
    color: {{ section.settings.accent_color }};
    text-align: center;
    font-family: Poppins;
    font-size: 32px;
    font-style: normal;
    font-weight: 600;
    line-height: 36px;
    text-transform: uppercase;
}

.content-grid {
  display: flex;
  flex-direction: column;
  gap: 6px;
  align-items: center;
  max-width: 1100px;
  margin: 0 auto;
}

.image-column, .text-column {
  width: 100%;
}

.main-image {
  width: 100%;
  height: auto;
  display: block;
}

.intro-text {
    margin-top: 16px;
    margin-bottom: 30px;
    color: #000;
    font-family: Poppins;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
}

.progress-item {
  margin-bottom: 40px;
}

.progress-header {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 10px;
}

.percentage {
    color: #000;
    text-align: center;
    leading-trim: both;
    text-edge: cap;
    font-family: Poppins;
    font-size: 50px;
    font-style: normal;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    min-width: 100px;
}

.block-text {
  margin: 0;
    color: #000;
    font-family: Poppins;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
}

.progress-bar-bg {
  width: 100%;
  height: 10px;
  background: #F3E7EB;
  border-radius: 5px;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: {{ section.settings.accent_color }};
  display: block !important;
}

.footer-note {
    margin-top: 0px;
    opacity: 0.8;
    color: #000;
    text-align: left;
    font-family: Poppins;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
}

/* Desktop Styles */
@media screen and (min-width: 768px) {
  .content-grid {
    flex-direction: row;
    align-items: flex-start;
    gap: 20px;
  }

  .image-column {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .text-column {
    flex: 1;
  }
}
</style>

<div class="science-results-container section-{{ section.id }}">
  <div class="page-width1">
    {% if section.settings.title != blank %}
      <h2 class="section-title">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="content-grid">
      <div class="image-column">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'main-image' }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}

        <div class="intro-text">
          {{ section.settings.intro_text }}
        </div>
      </div>

      <div class="text-column">
        <div class="progress-blocks">
          {% for block in section.blocks %}
            <div class="progress-item">
              <div class="progress-header">
                <span class="percentage">{{ block.settings.percentage }}%</span>
                <p class="block-text">{{ block.settings.text }}</p>
              </div>
              <div class="progress-bar-bg">
                <div class="progress-bar-fill" style="width: {{ block.settings.percentage }}%;"></div>
              </div>
            </div>
          {% endfor %}
        </div>

        {% if section.settings.footer_text != blank %}
          <div class="footer-note">
            {{ section.settings.footer_text }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Science Results Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "SCIENCE BACKED RESULTS"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro Text",
      "default": "<p>Traditional face masks sit on the surface...</p>"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer Note",
      "default": "<p>** These results are based on feedback...</p>"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#801a33"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Progress Block",
      "limit": 3,
      "settings": [
        {
          "type": "range",
          "id": "percentage",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Percentage",
          "default": 90
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Experienced smoother texture and more hydrated skin."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Science Results Section"
    }
  ]
}
{% endschema %}