        },
        "testimonial_HMtQi7": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/5_b09f08c9-4aba-455a-aa03-dcd7696f68b2.jpg",
            "stars_count": 5,
            "text": "<p>\"My skin looked so tired from work stress, but after using this mask a few times, it felt plumper and smoother. It’s like a reset for my face.\"</p>",
            "author": "- ELIF S"
          }
        },
        "testimonial_xpigwP": {
