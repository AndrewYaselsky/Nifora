    "ss_product_ingredients_6_fGKkBt": {
      "type": "ss-product-ingredients-6",
      "blocks": {
        "heading_TKcwVh": {
          "type": "heading",
          "settings": {
            "heading": "<p><strong>Every Ingredient Carefully Chosen</strong></p>",
            "heading_custom": false,
            "heading_font": "poppins_n7",
            "heading_size": 36,
            "heading_size_mobile": 32,
            "heading_height": 130,
            "heading_mt": 0,
            "heading_mt_mobile": 0,
            "heading_color": "#8b1638"
          }
        },
        "text_yqBznf": {
          "type": "text",
          "settings": {
            "text": "<p>Each ingredient in our <strong>Salmon PDRN Collagen Mask</strong> is carefully selected and backed by science—not hype. We use no harsh fillers or hidden additives—just a clean, transparent formula powered by clinically studied actives like Salmon PDRN, hydrolyzed collagen, niacinamide, and peptides to support skin repair, firmness, and visible rejuvenation.</p>",
            "text_custom": false,
            "text_font": "josefin_sans_n4",
            "text_size": 13,
            "text_size_mobile": 13,
            "text_height": 130,
            "text_mt": 4,
            "text_mt_mobile": 12,
            "text_color": "#121212"
          }
        },
        "card_EfXbF3": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/salmon_serum_1.png",
            "title": "Salmon PDRN",
            "text": "<p>Skin Repair</p>",
            "source": "",
            "modal_text": "<p><strong>Salmon PDRN</strong> supports <strong>skin renewal </strong>and <strong>repair</strong> by stimulating cell regeneration and improving elasticity. As skin ages, its natural ability to heal and restore weakens. PDRN helps boost recovery, <strong>strengthen the skin barrier</strong>, and promote a smoother, healthier, and more youthful complexion</p>",
            "modal_subtitle": "",
            "modal_sub_text": "",
            "url": ""
          }
        },
        "card_afErHY": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Niacinamide_78c86079-2000-4e45-a05f-61a2ff51585a.png",
            "title": "Niacinamide",
            "text": "<p>Brightening Agent</p>",
            "source": "",
            "modal_text": "<p><strong>Niacinamide </strong>is an ingredient that helps <strong>brighten skin tone</strong>, <strong>reduce the appearance of pores</strong>, and <strong>improve skin texture</strong>. It also strengthens the skin barrier, regulates oil production, and soothes inflammation—making it ideal for sensitive or aging skin. It enhances the overall <strong>clarity, smoothness, and resilience</strong> of the skin.</p>",
            "modal_subtitle": "",
            "modal_sub_text": "",
            "url": ""
          }
        },
        "card_Y4hUcX": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/gempages_560737037540394069-cf8b2d29-5a60-4e4b-b391-b74a74fba836.webp",
            "title": "Hydrolyzed Collagen",
            "text": "<p>Deep Absorption</p>",
            "source": "",
            "modal_text": "<p><strong>Our Salmon PDRN Mask uses fish collagen</strong> — a type of animal collagen extracted from the skin, scales, and gills of fish. It is widely used in food, health care products, and cosmetics due to its excellent absorption and skin-rejuvenating properties. <strong>It helps boost firmness and elasticity</strong>, enhances hydration by locking in moisture, and <strong>supports skin repair</strong>—visibly reducing the appearance of fine lines and <strong>promoting a smoother, plumper complexion</strong>.<br/></p>",
            "modal_subtitle": "",
            "modal_sub_text": "",
            "url": ""
          }
        },
        "card_CTtwny": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Peptides.png",
            "title": "Peptides",
            "text": "<p>Skin Firming</p>",
            "source": "",
            "modal_text": "<p><strong>Peptides</strong> help your <strong>skin stay firm</strong> and youthful by signaling cells to<strong> produce more collagen and elastin</strong>, the proteins responsible for strength and elasticity. This action not only improves the skin’s structure but also<strong> reduces the look of fine lines and wrinkles</strong>. By reinforcing the skin’s foundation, peptides enhance the overall plumpness and resilience of your complexion, making the mask’s rejuvenating effects even more noticeable.</p>",
            "modal_subtitle": "",
            "modal_sub_text": "",
            "url": ""
          }
        }
      },
