    "ss_simple_faq_NxVU6q": {
      "type": "ss-simple-faq",
      "blocks": {
        "text_kGtL6b": {
          "type": "text",
          "settings": {
            "question": "How does the wrinkle forehead patch work?",
            "answer": "<p>The patch uses medical-grade silicone to lock in moisture and gently compress the skin, helping to smooth fine lines and reduce wrinkles overnight</p>"
          }
        },
        "text_Xpzxzp": {
          "type": "text",
          "settings": {
            "question": "How long should I wear the patch?",
            "answer": "<p>For best results, wear the patch overnight while you sleep, typically 6–8 hours.</p>"
          }
        },
        "text_BDtRac": {
          "type": "text",
          "settings": {
            "question": "Is the patch suitable for sensitive skin?",
            "answer": "<p>Absolutely. It’s made from hypoallergenic, medical-grade silicone that’s gentle on all skin types, including sensitive skin.</p>"
          }
        },
        "text_UdqCJ3": {
          "type": "text",
          "settings": {
            "question": "When will I see results?",
            "answer": "<p>Many users notice smoother skin after just one use, with more visible improvements after consistent use over several weeks.<br/></p>"
          }
        },
        "text_3TN8mq": {
          "type": "text",
          "settings": {
            "question": "Can I use the patch with other skincare products?",
            "answer": "<p>Yes! Apply the patch on clean, dry skin. You can use your regular skincare routine before or after removing the patch.</p>"
          }
        },
        "text_Y9yyii": {
          "type": "text",
          "settings": {
            "question": "Is the patch safe to use every night?",
            "answer": "<p>It’s safe for regular use, but we recommend starting with a few nights a week to see how your skin responds.</p>"
          }
        },
        "text_XLQhWA": {
          "type": "text",
          "disabled": true,
          "settings": {
            "question": "Does it have a fragrance?",
            "answer": "<p>Water, glycerin, propylene glycol, betaine, sodium carrageenan, polyurethane-35, glucomannan, 1,2-hexanediol, hydroxyacetophenone, butylene glycol, hydroxyethylcellulose, pentylene glycol, dipotassium glycyrrhizate, panthenol, potassium chloride, allantoin, tocopheryl acetate (vitamin E), niacinamide (vitamin B3), hydrolyzed collagen, hydrolyzed sodium hyaluronate, sodium hyaluronate, hydroxyphenyl propamidobenzoic acid, Glycyrrhiza Uralensis (licorice) root extract, Tremella Fuciformis (snow mushroom) extract, fructose, Centella Asiatica extract, phosphatidylcholine, phenoxyethanol, ceramide NP, copper tripeptide-1, beta-sitosterol, beta-glucan, sodium stearoyl glutamate, ethylhexylglycerin, caprylhydroxamic acid, acetyl hexapeptide-8, palmitoyl tripeptide-5.</p>"
          }
        },
        "text_TCrhAW": {
          "type": "text",
          "settings": {
            "question": "60-Day Money back-guarantee?",
            "answer": "<p>Yes! We stand behind the quality of our products. If you’re not satisfied with your purchase, you can request a return within 60 days of receiving your order. Simply contact our support team, and we’ll guide you through the process.</p>"
          }
        },
        "text_ntbDgy": {
