    bottom: 0;
    content: "";
    height: 95%;
    position: absolute;
    z-index: 0;
    left: 50%;
    top: 20px;
    width: 3px;
    transform: translateX(-50%);
    background-color: #2f0147;
}
.gps .ggWRdunce3 .gps_timeline-item:not(:last-child):before {
    content: '';
    position: absolute;
    left: 50%;
    top: 20px;
    height: var(--timeline-height-dynamic);
    background: #ff699f;
    transition: height 0.2s ease-out;
    z-index: 1;
    width: 3px;
    transform: translateX(-50%);
}
.gps .ggWRdunce3 .gps_timeline-icon svg{
    color: #2f0147 !important;
    transition: all 0.4s ease;
    z-index: 9999999999!important;
}
.gps .ggWRdunce3 .gps_timeline-icon{
    z-index: 9999999!important;
}

.gps .ggWRdunce3 .gps_timeline-icon.isActive svg{
    color: var(--c) !important;
}

.gps .ggWRdunce3 .gps_timeline-icon .icon-wrapper {
    transition: all 0.4s ease;
    background-color: #2f0147 !important;
}

.gps .ggWRdunce3 .gps_timeline-icon.isActive .icon-wrapper{
    background-color: var(--bg) !important;
}

.gps .ggWRdunce3 .gps_timeline-box {
    overflow: visible !important;
    transform: translateX(50px);
    opacity: 0 !important;
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
}

.gps .ggWRdunce3 .gps_timeline-box.gps_left-box {
    transform: translateX(-50px);
}

.gps .ggWRdunce3 .gps_timeline-item.viewing .gps_timeline-box {
    opacity: 1 !important;
    transform: translateX(0);
}

.gps .ggWRdunce3 .gps_timeline-box svg {
    transform: rotate(0deg);
    transition: transform 0.5s ease-out;
}

.gps .ggWRdunce3 .gps_timeline-item.viewing .gps_timeline-box svg {
    transform: rotate(360deg);
}

.gps .ggWRdunce3 .gps_timeline-box:before {
    content: "";
    position: absolute;
    top: 15px;
    left: -15px;
    border-top: 13px solid transparent;
    border-bottom: 13px solid transparent;
    border-right: 13px solid #2f0147;
}

.gps .ggWRdunce3 .gps_timeline-box.gps_left-box:before {
    border-right: none;
    border-left: 13px solid #2f0147;
    left: auto;
    right: -15px;
