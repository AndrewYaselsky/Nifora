        "ggFYCvYdkkz_text": "<span style=\"background-color:transparent;color:#000000;font-size:36px;\">Are you finally ready to give your skin the repair it deserves? 💞</span>",
        "ggHIzq54zz__text": "5. Celebrity-Favorite",
        "ggIu24cKJ2N_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0798/4028/0923/files/gempages_560737037540394069-27b150b2-4d34-4a80-a224-740e5f9bc8f3.png",
