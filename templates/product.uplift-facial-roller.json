        "de158e68-5d0d-4819-a625-e2dabdff87d1": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Key Benefits",
            "heading_size": "small",
            "icon": "check_box",
            "filled_icon": false,
            "collapse_icon": "carret",
            "display_top_border": true,
            "open": false,
            "content": "<p><strong>Radiant Skin</strong>: Daily use of the roller, with its 30 massage stones infused with germanium powder, helps invigorate the skin and facial muscles, giving you a healthy, youthful glow.</p><p><strong>De-puff and Contour</strong>: Cool to the touch, the roller aids in reducing puffiness by promoting lymphatic drainage. For extra benefits, store it in the fridge!</p><p><strong>Uplift and Firm</strong>: The massaging action tightens and firms facial muscles, enhancing your natural contours and smoothing out fine lines and wrinkles.</p><p><strong>Product Absorption</strong>: After applying your skincare, use the roller to improve product absorption for better results. It’s easy to clean with soap or rubbing alcohol.</p><p><strong>Tension Relief</strong>: Like a facial massage, the roller helps release tension in facial muscles, and it’s great for the jaw, neck, or anywhere you feel tightness.</p>",
            "page": "",
            "margin_top": 0,
            "margin_bottom": 0
          }
        },
        "collapsible_tab_QnkEdx": {
          "type": "collapsible_tab",
          "settings": {
