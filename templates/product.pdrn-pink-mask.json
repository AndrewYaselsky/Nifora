    "multirow_gFb6FN": {
      "type": "multirow",
      "blocks": {
        "row_aRa7x9": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/103b8aa6cbf231bfc714536afca72b00.jpg",
            "caption": "",
            "title": "Meet Your Skin’s New Best Friend - <strong>Salmon PDRN</strong>",
            "title_highlight_color": "#8b1638",
            "text": "<p><strong>Salmon PDRN </strong>(Polydeoxyribonucleotide) is a skin-revitalizing compound derived from <strong>salmon DNA</strong> — known for its purity and compatibility with the skin. Used in advanced aesthetic care, it helps <strong>stimulate cell regeneration</strong>, <strong>boost collagen</strong>, and <strong>restore firmness and elasticity</strong> for a smoother, more youthful complexion.</p>",
            "button_label": "",
            "button_link": "",
