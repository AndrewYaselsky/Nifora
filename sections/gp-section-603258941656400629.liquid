      <script id="custom-js-gybgdvDCwX">
        try {
          document.addEventListener("DOMContentLoaded", function () {
  const stickyTarget = document.querySelector('.sticky-top-section');
  const placeholder = document.createElement('div');

  if (stickyTarget) {
    const height = stickyTarget.offsetHeight;
    placeholder.style.height = height + 'px';
    placeholder.style.display = 'none';
    stickyTarget.parentNode.insertBefore(placeholder, stickyTarget);

    window.addEventListener('scroll', function () {
      if (window.scrollY > 10) {
        stickyTarget.style.position = 'fixed';
        stickyTarget.style.top = '0';
        stickyTarget.style.left = '0';
        stickyTarget.style.right = '0';
        stickyTarget.style.zIndex = '9999';
        stickyTarget.style.background = '#8A1538';
        placeholder.style.display = 'block';
      } else {
        stickyTarget.style.position = '';
        stickyTarget.style.top = '';
        stickyTarget.style.left = '';
        stickyTarget.style.right = '';
        stickyTarget.style.zIndex = '';
        stickyTarget.style.background = '';
        placeholder.style.display = 'none';
      }
    });
  }
});

        } catch(err){}
