    "ss_testimonial_10_MJHF8K": {
      "type": "ss-testimonial-10",
      "blocks": {
        "testimonial_78YWhM": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/61_qbnPScJL.jpg",
            "stars_count": 5,
            "text": "<p>“I’ve tried countless masks over the years, but this one genuinely surprised me. I’m in my mid-40s, and my skin has been feeling more dehydrated lately. After just one use, my face felt plump, moisturized, and smoother. It’s now my weekly go-to treat!”</p>",
            "author": "- Lisa M."
          }
        },
        "testimonial_HMtQi7": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/moments_in_may.jpg",
            "stars_count": 5,
            "text": "<p>“My skin tends to get flaky and tight, especially during colder months. This mask delivers an instant surge of hydration and leaves my skin feeling like silk. Plus, it gives me that fresh glow without any irritation. Love the cooling texture too!”</p>",
            "author": "- Jasmine R."
          }
        },
        "testimonial_xpigwP": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/the_medicube_global_official_line_has_officially_been_life_changing_for_me._that_s_all._that_s_the_post..jpg",
            "stars_count": 5,
            "text": "<p>“As someone with mature skin, I’m always on the hunt for products that help with dryness and fine lines. The salmon collagen in this mask is a game changer. My skin feels firmer and more hydrated — and even my laugh lines look softer. It’s a little miracle in a pouch!”</p>",
            "author": "- Angela C."
          }
        },
        "testimonial_yyRRp8": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/cc624c9ce5edd3e6e01314c38ed6512b.jpg",
            "stars_count": 5,
            "text": "<p>“I didn’t expect much at first, but wow — my skin soaked this right up. It feels like a spa treatment at home! Super hydrating without feeling sticky, and my skin looks noticeably more refreshed the next day. Definitely a keeper.”<br/></p>",
            "author": "- Nina T."
          }
        },
        "testimonial_K9emEj": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/71P9Et_--ML.jpg",
            "stars_count": 5,
            "text": "<p>\"I have sensitive, combination skin, and this mask worked beautifully. No breakouts, no redness — just smooth, hydrated, glowing skin.\"</p>",
            "author": "- Kaia"
          }
        }
      },
      "block_order": [
        "testimonial_78YWhM",
