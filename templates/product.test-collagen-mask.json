    "custom_liquid_fbTAUw": {
      "type": "custom-liquid",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<div class=\"product__block product__features\" data-slider=\"\" style=\"--PBB:20px;\">\n  <div class=\"product__feature\" data-block-id=\"feature_A3b4kT\">\n    <div class=\"product__feature__content\">\n      <div class=\"product__feature__icon__container\">\n        <!-- Main Headline -->\n        <div class=\"product__feature__headline\">\n          <h3>TRY US RISK FREE</h3>\n        </div>\n        <!-- Subheadline -->\n        <div class=\"product__feature__heading\">\n          <h5><strong>60-Day Money-Back Guarantee</strong></h5>\n        </div>\n      </div>\n      <div class=\"product__feature__text\">\n        <p><br>We're confident you'll love <span style=\"text-decoration:underline\"><strong>our Face Masks.</strong></span>  If for any reason you're not satisfied or don't see visible improvement in your skin, we'll refund your order - no questions asked.</p>\n      </div>\n    </div>\n  </div>\n</div>\n\n<style>\n  /* Minimalist background for the block */\n  .product__feature {\n    background: #f7f7f7; /* Soft light gray */\n    padding: 20px;\n    border-radius: 8px;\n    box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.05); /* Very subtle shadow */\n    border: 1px solid #eaeaea; /* Light border for definition */\n    max-width: 450px; /* Keeps it clean */\n    margin: auto; /* Centers the block horizontally */\n    text-align: left; /* Ensures everything is left-aligned */\n  }\n\n  /* Main Headline */\n  .product__feature__headline h3 {\n    font-size: 26px;\n    font-weight: bold;\n    color: #000;\n    margin-bottom: 5px;\n    text-align: left; /* Left align */\n  }\n\n  /* Subheadline */\n  .product__feature__heading h5 {\n    font-size: 18px;\n    font-weight: 600;\n    color: #8b1638;\n    text-transform: none; /* Capitalizes only the first letters */\n    margin: 0;\n    text-align: left; /* Left align */\n  }\n\n  /* Text content */\n  .product__feature__text p {\n    font-size: 16px;\n    color: #000;\n    line-height: 24px;\n    text-align: left; /* Left align */\n  }\n\n  /* Mobile adjustments */\n  @media (max-width: 500px) {\n    .product__feature {\n      padding: 15px;\n      max-width: 100%;\n    }\n\n    .product__feature__headline h3 {\n      font-size: 20px;\n    }\n\n    .product__feature__heading h5 {\n      font-size: 15px;\n    }\n\n    .product__feature__text p {\n      font-size: 15px;\n      line-height: 22px;\n    }\n  }\n</style>",
