    "custom_liquid_gyrR9z": {
      "type": "custom-liquid",
      "disabled": true,
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<!DOCTYPE html> \n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Responsive Photo Slider</title>\n    <style>\n        body {\n            font-family: 'Avenir Next', sans-serif;\n            background-color: #f7f7f7;\n            margin: 0;\n            padding: 0;\n        }\n\n        .slider-container {\n            position: relative;\n            max-width: 1200px;\n            margin: 20px auto;\n            overflow: hidden;\n            border-radius: 15px;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);\n            background-color: #fff;\n            padding: 10px;\n        }\n\n        .slider {\n            display: flex;\n            will-change: transform;\n            transition: transform 0.4s ease-out;\n        }\n\n        .slide {\n            min-width: 70%;\n            box-sizing: border-box;\n            margin: 0 10px;\n            position: relative;\n            transition: transform 0.5s ease;\n        }\n\n        .slide img {\n            width: 100%;\n            height: auto;\n            border-radius: 10px;\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);\n        }\n\n        .headline {\n            font-size: 1.2rem;\n            font-weight: 700;\n            text-align: center;\n            color: #3a3a3a;\n            margin: 20px 0 10px 0;\n        }\n\n        .subheadline {\n            font-size: 1rem;\n            text-align: center;\n            color: #666;\n            margin-bottom: 30px;\n            max-width: 80%;\n            margin-left: auto;\n            margin-right: auto;\n        }\n\n        .before-after-header {\n            font-size: 1.3rem; /* Slightly smaller than the main headline */\n            font-weight: 600;\n            text-align: center;\n            color: #8b1638; /* Warm Nude */\n            margin-bottom: 10px;\n        }\n\n        /* Desktop View Adjustments */\n        @media (min-width: 768px) {\n            .slide {\n                min-width: 30%;\n            }\n        }\n\n        @media (min-width: 1024px) {\n            .slider-container {\n                max-width: 1400px;\n            }\n        }\n\n        /* Hover effect for slides */\n        .slide:hover img {\n            transform: scale(1.05);\n        }\n\n        /* Fancy text shadows */\n        .headline, .subheadline {\n            text-shadow: 1px 1px 5px rgba(0, 0, 0, 0.15);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"headline\">Get a Healthier Skin ✨</div>\n    <div class=\"subheadline\">From dull and dry to glowy, hydrated and smooth! Our mask provides a glass-like finish, refines skin texture and is suitable for even the most sensitive skin. Perfect for an instant radiant look! 💖</div>\n\n    <!-- New Before & After Header -->\n    <div class=\"before-after-header\">Before & After</div>\n\n    <div class=\"slider-container\">\n        <div class=\"slider\">\n            <div class=\"slide\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0798/4028/0923/files/12_0dc3cdd5-a145-4b73-94c9-c2e3757ef30a.png?v=1748944785\" alt=\"Image 1\">\n            </div>\n            <div class=\"slide\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0798/4028/0923/files/32_df2e5825-dd39-4f21-b55d-bd7beae3dc54.png?v=1748874386\" alt=\"Image 2\">\n            </div>\n            <div class=\"slide\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0798/4028/0923/files/33.png?v=1748874385\" alt=\"Image 3\">\n            </div>\n            <div class=\"slide\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0798/4028/0923/files/34_75a854e0-a83a-4c19-bbae-acf02c786216.png?v=1748874385\" alt=\"Image 4\">\n            </div>\n        </div>\n    </div>\n\n    <script>\n        (function() {\n            const slider = document.querySelector('.slider');\n            const slides = document.querySelectorAll('.slide');\n            const slideWidth = slides[0].offsetWidth + 20; // Includes margin\n            const totalSlides = slides.length;\n\n            let isDragging = false;\n            let startX = 0;\n            let currentTranslate = 0;\n            let previousTranslate = 0;\n            let velocity = 0;\n\n            const setSliderPosition = () => {\n                slider.style.transform = `translateX(${currentTranslate}px)`;\n            };\n\n            const startDragging = (x) => {\n                isDragging = true;\n                startX = x;\n                slider.style.transition = 'none';\n            };\n\n            const drag = (x) => {\n                if (!isDragging) return;\n                const delta = x - startX;\n                currentTranslate = previousTranslate + delta;\n                setSliderPosition();\n                velocity = delta;\n            };\n\n            const stopDragging = () => {\n                if (!isDragging) return;\n                isDragging = false;\n\n                const momentumTranslate = currentTranslate + velocity * 3;\n                const maxTranslate = 0;\n                const minTranslate = -(slideWidth * (totalSlides - 1));\n\n                currentTranslate = Math.min(maxTranslate, Math.max(minTranslate, momentumTranslate));\n                previousTranslate = currentTranslate;\n\n                const index = Math.round(-currentTranslate / slideWidth);\n                currentTranslate = -index * slideWidth;\n                previousTranslate = currentTranslate;\n\n                slider.style.transition = 'transform 0.5s ease-out';\n                setSliderPosition();\n            };\n\n            slider.addEventListener('mousedown', (e) => startDragging(e.clientX));\n            slider.addEventListener('mousemove', (e) => drag(e.clientX));\n            slider.addEventListener('mouseup', stopDragging);\n            slider.addEventListener('mouseleave', stopDragging);\n            slider.addEventListener('touchstart', (e) => startDragging(e.touches[0].clientX));\n            slider.addEventListener('touchmove', (e) => drag(e.touches[0].clientX));\n            slider.addEventListener('touchend', stopDragging);\n\n            document.addEventListener('dragstart', (e) => e.preventDefault());\n        })();\n    </script>\n</body>\n</html>",
        "color_scheme": "background-1",
