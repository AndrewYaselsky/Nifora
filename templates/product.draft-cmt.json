    "ss_simple_faq_NxVU6q": {
      "type": "ss-simple-faq",
      "blocks": {
        "text_6Tawgb": {
          "type": "text",
          "settings": {
            "question": "How do I use the collagen mouth tape?",
            "answer": "<p>Simply apply the tape over clean, dry lips before bed. Make sure your lips are free from oils or balm so it adheres properly. Remove gently in the morning.</p>"
          }
        },
        "text_73a8gE": {
          "type": "text",
          "settings": {
            "question": "Is it safe to use every night?",
            "answer": "<p>Yes! The tape is made with hypoallergenic, breathable, latex-free materials designed for nightly use. If you have adhesive sensitivities, we recommend a patch test first.</p>"
          }
        },
        "text_RHByhb": {
          "type": "text",
          "settings": {
            "question": "Can I breathe while wearing it?",
            "answer": "<p>Yes — as long as you can comfortably breathe through your nose. The tape encourages nasal breathing but does not block airflow or seal your mouth tightly.</p>"
          }
        },
        "text_zEQmD3": {
          "type": "text",
          "settings": {
            "question": "What benefits can I expect?",
            "answer": "<p>Most customers experience reduced snoring, fewer dry-mouth mornings, smoother lips, and more restful sleep thanks to consistent nasal breathing.</p>"
          }
        },
        "text_fDnyCx": {
          "type": "text",
          "settings": {
            "question": "Will it hurt to take off?",
            "answer": "<p>No. The adhesive is gentle and skin-friendly. It removes smoothly without pulling the skin or leaving sticky residue.</p>"
          }
        },
        "text_3NnC6c": {
          "type": "text",
          "settings": {
            "question": "Will the tape stay on all night?",
            "answer": "<p>Yes! When applied on clean, dry lips, the adhesive is designed to stay securely in place throughout the night — without feeling harsh or uncomfortable.</p>"
          }
        },
        "text_FHaPJq": {
          "type": "text",
          "settings": {
            "question": "Does the collagen actually plump the lips?",
            "answer": "<p>The collagen-infused center helps deliver hydration and lock in moisture overnight, which can make lips appear smoother, softer, and subtly plumper by morning.</p>"
          }
        },
        "text_wQKE4g": {
          "type": "text",
          "settings": {
            "question": "Can I use lip balm before applying the tape?",
            "answer": "<p>It’s best <strong>not</strong> to apply lip balm or oils beforehand, as they can prevent the tape from sticking properly. For best results, apply the tape on clean, dry lips — the hydration comes from the collagen patch itself.</p>"
          }
        }
      },
