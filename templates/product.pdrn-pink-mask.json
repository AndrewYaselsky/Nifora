          }
        },
        "row_ayrL8c": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/Untitled_design_2_f8c47b58-64be-4162-b91b-ab9765cde65b.png",
            "caption": "",
            "title": "<strong>Clinically Proven</strong> Hydration & Firmness",
            "title_highlight_color": "#8b1638",
            "text": "<p><strong>Specially made for mature</strong>, <strong>dehydrated skin</strong>, this collagen-rich hydrogel mask instantly hydrates, firms, and revives dull skin—plumping fine lines and smoothing texture for a radiant, youthful glow.</p><p><strong>Clinically tested</strong> to show visible results — including <strong>improved elasticity</strong>, <strong>smoother skin</strong>, and up to a <strong>79% boost in hydration after one use</strong> — it’s your self-care secret for skin that looks as fresh as it feels.</p>",
            "button_label": "",
            "button_link": "",
            "atc_button_label": "",
            "atc_product": "",
            "atc_skip_cart": false
          }
        },
        "row_pF4mCm": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/86.png",
            "caption": "",
            "title": "<strong>Refine, Brighten & Restore </strong>with Salmon PDRN",
            "title_highlight_color": "#8b1638",
            "text": "<p>Harness the regenerative power of <strong>Salmon PDRN</strong>, a clinically celebrated ingredient known for its ability to <strong>revitalize and repair the skin at a cellular level</strong>. This potent DNA complex helps <strong>refine texture</strong>, <strong>brighten dullness</strong>, and <strong>restore firmness</strong> by accelerating cell turnover and boosting collagen synthesis. With consistent use, your complexion appears smoother, more even-toned, and visibly renewed — revealing the radiant vitality of truly healthy skin. </p>",
            "button_label": "",
            "button_link": "",
            "atc_button_label": "",
            "atc_product": "",
            "atc_skip_cart": false
          }
        },
        "row_nnbML9": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/Rebranding_Photos_8_a4239662-7870-4514-a7fa-7c92eeb020e7.png",
            "caption": "",
            "title": "<strong>Pore & Dark Spot Refinement</strong>",
            "title_highlight_color": "#8b1638",
            "text": "<p>Infused with <strong>Niacinamide</strong> and <strong>Salmon PDRN</strong>, this advanced formula helps <strong>refine pores</strong>, <strong>fade dark spots</strong>, and <strong>brighten uneven skin tone</strong> for a visibly smoother complexion. By supporting skin regeneration and improving elasticity, it minimizes the appearance of texture and discoloration while restoring a healthy, balanced glow. With regular use, pores appear tighter, skin looks clearer, and radiance is noticeably renewed.</p>",
            "button_label": "",
            "button_link": "",
            "atc_button_label": "",
