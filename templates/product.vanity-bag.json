          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/1.jpg",
            "stars_count": 5,
            "text": "<p>\"I was scared to try anything with collagen because of my acne-prone skin, but this one actually reduced redness and helped my breakouts heal faster.\"</p>",
