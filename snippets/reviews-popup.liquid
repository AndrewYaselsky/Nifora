<script defer="defer" src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.js"></script>

<script>
  let reviewSwiper = null;

  function initReviewSwiper() {
    const popup = document.getElementById('reviewPopup');
    if (!popup) return;
    
    const swiperElement = popup.querySelector('.mySwiper');
    if (!swiperElement) return;

    // If Swiper already exists, destroy it first
    if (reviewSwiper) {
      reviewSwiper.destroy(true, true);
      reviewSwiper = null;
    }

    // Check if Swiper is loaded
    if (typeof Swiper === 'undefined') {
      // Wait for Swiper to load
      setTimeout(initReviewSwiper, 100);
      return;
    }

    // Get the navigation buttons from within the popup
    const prevButton = popup.querySelector('.custom-prev-button');
    const nextButton = popup.querySelector('.custom-next-button');
    // Find pagination element - it's inside the swiper container
    const paginationEl = swiperElement.querySelector('.swiper-pagination');

    if (!prevButton || !nextButton) {
      console.error('Navigation buttons not found');
      return;
    }

    // Build config object
    const swiperConfig = {
      slidesPerView: 1,
      spaceBetween: 20,
      loop: false,
      navigation: {
        nextEl: nextButton,
        prevEl: prevButton,
        disabledClass: 'swiper-button-disabled',
      },
      breakpoints: {
        750: {
          slidesPerView: 1,
          spaceBetween: 30,
        },
      },
    };

    // Only add pagination if the element exists
    if (paginationEl) {
      swiperConfig.pagination = {
        el: paginationEl,
        clickable: true,
        type: 'bullets',
      };
    }

    // Initialize Swiper
    reviewSwiper = new Swiper(swiperElement, swiperConfig);
  }

  function toggleReviews() {
    const popup = document.getElementById('reviewPopup');
    popup.classList.toggle('is-visible');
    
    // Initialize or update Swiper when popup becomes visible
    if (popup.classList.contains('is-visible')) {
      // Small delay to ensure popup is rendered
      setTimeout(function() {
        initReviewSwiper();
      }, 100);
    }
  }

  // Initialize when DOM is ready and Swiper is loaded
  document.addEventListener('DOMContentLoaded', function () {
    // Wait a bit for Swiper script to load
    setTimeout(function() {
      const popup = document.getElementById('reviewPopup');
      if (popup && popup.classList.contains('is-visible')) {
        initReviewSwiper();
      }
    }, 200);
  });

  // Also try to initialize when Swiper loads
  window.addEventListener('load', function() {
    const popup = document.getElementById('reviewPopup');
    if (popup && popup.classList.contains('is-visible')) {
      setTimeout(initReviewSwiper, 100);
    }
  });

  // Close when clicking outside
  window.addEventListener('click', function (e) {
    const container = document.getElementById('reviewContainer');
    if (container && !container.contains(e.target)) {
      document.getElementById('reviewPopup').classList.remove('is-visible');
    }
  });
</script>
