            "collapse_icon": "carret",
            "display_top_border": true,
            "open": false,
            "content": "<p>Roll the device across forehead, jawline, cheeks, neck, or anywhere as needed using gentle massaging motions. Use daily for best results.</p>",
            "page": "",
            "margin_top": 24,
