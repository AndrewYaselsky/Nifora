          "settings": {
            "image": "shopify://shop_images/1722543832__20240731_203542__original.png",
            "stars_count": 5,
            "text": "<p>\"I started noticing smile lines, and this mask really helped soften them. It’s not magic overnight, but my skin feels firmer and more elastic.\"</p>",
