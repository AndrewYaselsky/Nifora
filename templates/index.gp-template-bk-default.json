        "text_4Vbrfr": {
          "type": "text",
          "settings": {
            "text": "<p>Most sheet masks look the same—but there are <em>critical differences</em> that determine how well they actually perform for your skin. Here’s why ours stands out:</p>",
            "text_custom": false,
            "text_font": "josefin_sans_n4",
