            "desktop_spacing": 12,
            "desktop_text_size": 18,
            "mobile_icon_size": 28,
            "mobile_spacing": 6,
            "mobile_text_size": 14,
            "icon_1": "undo",
            "icon_1_fill": false,
            "heading_1": "60 DAY RETURN",
            "icon_2": "local_shipping",
            "icon_2_fill": false,
            "heading_2": "FREE SHIPPING",
            "icon_3": "star",
            "icon_3_fill": false,
            "heading_3": "1 YEAR WARRANTY",
