    "ss_testimonial_10_MJHF8K": {
      "type": "ss-testimonial-10",
      "blocks": {
        "testimonial_78YWhM": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/716HP_e9XjL.jpg",
            "stars_count": 5,
            "text": "<p>“I’ve been waking up with deep chest lines for years from side-sleeping. After just a few nights with this patch, I noticed a huge improvement. The lines are less visible and my skin feels much softer. It’s now a must in my nighttime routine!”</p>",
            "author": "- Jennifer"
          }
        },
        "testimonial_HMtQi7": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/1678921e47a4f7ec48b658e79069ff73.jpg",
            "stars_count": 5,
            "text": "<p>“I wasn’t sure if this would actually work, but it’s surprisingly effective. The patch stays on all night, and by morning, my chest looks noticeably smoother. It’s reusable too, which makes it worth the price. I just wish I had found this sooner!”</p>",
            "author": "- Jessica"
          }
        },
        "testimonial_xpigwP": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/29a4e799-734e-46aa-bfcb-d07d9ca358ed_full_size.jpg",
            "stars_count": 5,
            "text": "<p>“As someone in their 50s, I’ve tried lots of anti-aging products. This chest patch is one of the few that gave me instant, visible results. It’s comfortable to wear and really helps reduce those fine lines on my chest. Highly recommend!”</p>",
            "author": "- Angie"
          }
        },
        "testimonial_yyRRp8": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/5e5f31de-464d-4047-97e8-71ae0f8452da_full_size.jpg",
            "stars_count": 5,
            "text": "<p>“I’ve been using the patch for about two weeks now and can already see my chest wrinkles fading. It's gentle, doesn’t irritate my skin, and feels like a little self-care moment every night. It’s definitely helped improve my confidence in lower-cut tops.”</p>",
            "author": "- Rache"
          }
        },
        "testimonial_K9emEj": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/SnapInsta.to_366139621_325551473163928_7336591282351157664_n.jpg",
            "stars_count": 5,
            "text": "<p>“This chest wrinkle patch is amazing! I saw smoother skin after the first night. I’ve used it consistently and my lines have softened so much. It’s easy to apply, reusable, and stays put even when I toss and turn. Love it!”</p>",
            "author": "- Stephanie"
          }
        }
      },
