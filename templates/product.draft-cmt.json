        "row_pF4mCm": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/Mouth_Tape.png",
            "caption": "",
            "title": "Made for<strong> </strong><em><strong>All</strong></em><strong> Sleepers</strong>",
            "title_highlight_color": "#8b1638",
            "text": "<p>Whether you’re a light dozer, a heavy snorer, or someone with sensitive skin — our <strong>Collagen Mouth Tape is designed for gentle nightly use</strong>. The breathable, hypoallergenic cotton exterior, combined with a carefully calibrated adhesive, ensures a snug but <strong>comfortable fit </strong>that <strong>stays put overnight</strong> without irritation.</p>",
            "button_label": "",
