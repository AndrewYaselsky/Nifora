        "gggNu3h2MeZ_text": "<p><span style=\"background-color:#FFFFFF;\">The Real Differences Between</span><br><span style=\"background-color:#FFFFFF;\">The Top 5 Masks &amp; Our Clear Winner!</span></p>",
        "ggh5kzCBrcz_label": "<p>Check availability</p>",
