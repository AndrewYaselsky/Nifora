        "testimonial_78YWhM": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/719rWf5ITiL.jpg",
            "stars_count": 5,
            "text": "<p>\"I’ve been using this cream for about 3 weeks, and my neck already looks smoother and more toned. It absorbs quickly and doesn’t feel sticky. I’m impressed!\"</p>",
            "author": "- Lori"
          }
        },
        "testimonial_HMtQi7": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/71PLOHRvnpL.jpg",
            "stars_count": 5,
            "text": "<p>\"As someone in my 50s, I’ve noticed my neck skin becoming looser. This cream has made a big difference—firmer, softer, and visibly more youthful.\"</p>",
            "author": "- Beth"
          }
        },
        "testimonial_xpigwP": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/71GI0dg_ifL.jpg",
            "stars_count": 5,
            "text": "<p>\"I love how rich but lightweight this cream feels. No irritation, and my skin stays hydrated all night. Definitely a new staple in my routine!\"</p>",
            "author": "- Samantha"
          }
        },
        "testimonial_yyRRp8": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/71ZSC9hphLL.jpg",
            "stars_count": 5,
            "text": "<p>\"Didn’t expect dramatic results overnight, but after consistent use, I see real improvement in firmness and texture. It’s a gentle but effective product.\"</p>",
            "author": "- Emma W."
          }
        },
        "testimonial_K9emEj": {
          "type": "testimonial",
          "settings": {
            "image": "shopify://shop_images/81Bi7YAJOzL.jpg",
            "stars_count": 5,
            "text": "<p>\"I have sensitive skin, and this is one of the few neck creams that didn’t cause redness or breakouts. After a month, my skin feels firmer and looks more even-toned.\"</p>",
            "author": "- Lilia S."
          }
        }
