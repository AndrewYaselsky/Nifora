            "slider_type": "slide",
            "autoplay": false,
            "autoplay_speed": 5,
            "display_arrows": false,
            "display_dots": false,
            "author_1": "Dr. Layla Hassan, MD, Board-Certified Dermatologist",
            "image_1": "shopify://shop_images/images.jpg",
            "text_1": "<p>\"Nifora’s Bio-Collagen Mask is clinically proven to boost skin hydration, reduce signs of aging, and enhance overall skin health. As a dermatologist, I highly recommend it for achieving a radiant, youthful complexion.\"</p>",
            "author_2": "<em>Author</em> [stars]",
            "text_2": "<p>Share positive thoughts and feedback from your customer.</p>",
            "author_3": "<em>Author</em> [stars]",
