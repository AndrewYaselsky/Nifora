      <script id="custom-js-gADJnKzyve">
        try {
          document.addEventListener("DOMContentLoaded", (event) => {
    const currentElement = document.getElementsByClassName('gADJnKzyve');
    const timeline = currentElement[0].querySelector('.gps_timeline-section');
    const items = currentElement[0].querySelectorAll('.gps_timeline-item');

    function updateTimeline() {
      const firstItem = currentElement[0].querySelector('.gps_timeline-item-start');
      const firstTop = firstItem.getBoundingClientRect().top + window.scrollY;
      const lastItem = items[items.length - 1];
      const lastTop = lastItem.getBoundingClientRect().top + window.scrollY;
      const scrollTop = window.scrollY + window.innerHeight * 0.6;
      const maxHeight = lastTop - firstTop;
      const dynamicHeight = Math.min(Math.max(scrollTop - firstTop, 0), maxHeight);

      firstItem.style.setProperty('--timeline-height-dynamic', `${dynamicHeight}px`);
      items.forEach(item => {
        const itemTop = item.getBoundingClientRect().top + window.scrollY;
        if (scrollTop >= itemTop - 50) {
          item.classList.add('viewing');
          item.querySelector('.gps_timeline-icon').classList.add('isActive')
        } else {
          item.classList.remove('viewing');
          item.querySelector('.gps_timeline-icon').classList.remove('isActive')
        }
      });
    }

    window.addEventListener('scroll', updateTimeline);
    window.addEventListener('resize', updateTimeline);
    window.addEventListener('load', updateTimeline);
});

        } catch(err){}
      </script>
    
